<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Calculadora Câmeras IP</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
  <style>
    body { font-family: 'Segoe UI', system-ui, sans-serif; }
  </style>
</head>
<body class="bg-gray-950 text-white min-h-screen">
  <div class="max-w-4xl mx-auto p-6">
    <h1 class="text-4xl font-bold text-center mb-2 text-blue-500">
      📷 Calculadora de Câmeras IP
    </h1>
    <p class="text-center text-gray-400 mb-8">Otimize sua rede sem travar!</p>

    <div class="bg-gray-900 rounded-2xl p-8 shadow-xl">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <!-- Inputs -->
        <div>
          <label class="block text-sm font-medium mb-2">Total de Câmeras</label>
          <input id="cameras" type="number" value="14" 
                 class="w-full bg-gray-800 rounded-lg px-4 py-3 text-lg focus:outline-none focus:ring-2 focus:ring-blue-500">
        </div>

        <div>
          <label class="block text-sm font-medium mb-2">Resolução Principal</label>
          <select id="resolucao" class="w-full bg-gray-800 rounded-lg px-4 py-3">
            <option value="1080">1080p (Full HD)</option>
            <option value="720">720p (HD)</option>
            <option value="4k">4K (3840x2160)</option>
          </select>
        </div>

        <div>
          <label class="block text-sm font-medium mb-2">Codec</label>
          <select id="codec" class="w-full bg-gray-800 rounded-lg px-4 py-3">
            <option value="h265">H.265 (melhor compressão)</option>
            <option value="h264" selected>H.264</option>
          </select>
        </div>

        <div>
          <label class="block text-sm font-medium mb-2">Velocidade da Rede (Mbps)</label>
          <select id="rede" class="w-full bg-gray-800 rounded-lg px-4 py-3">
            <option value="100">100 Mbps</option>
            <option value="200" selected>200 Mbps</option>
            <option value="500">500 Mbps</option>
            <option value="1000">1 Gbps</option>
          </select>
        </div>
      </div>

      <button onclick="calcular()" 
              class="mt-8 w-full bg-blue-600 hover:bg-blue-700 transition py-4 rounded-xl text-xl font-semibold">
        Calcular Configuração Ideal
      </button>
    </div>

    <!-- Resultado -->
    <div id="resultado" class="mt-8 hidden">
      <h2 class="text-2xl font-bold mb-6 text-center">✅ Configuração Recomendada</h2>
      
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <!-- MainStream -->
        <div class="bg-gray-900 rounded-2xl p-6">
          <h3 class="text-xl font-semibold text-green-400 mb-4">📹 MainStream (Gravação)</h3>
          <table class="w-full text-sm">
            <tr class="border-b border-gray-700"><td class="py-2">Resolução</td><td id="main_res" class="text-right font-medium"></td></tr>
            <tr class="border-b border-gray-700"><td class="py-2">Codec</td><td id="main_codec" class="text-right font-medium"></td></tr>
            <tr class="border-b border-gray-700"><td class="py-2">FPS</td><td id="main_fps" class="text-right font-medium"></td></tr>
            <tr class="border-b border-gray-700"><td class="py-2">I-Frame</td><td id="main_iframe" class="text-right font-medium"></td></tr>
            <tr class="border-b border-gray-700"><td class="py-2">Bitrate por câmera</td><td id="main_bitrate" class="text-right font-medium"></td></tr>
            <tr><td class="py-2 font-bold">Total estimado</td><td id="total_band" class="text-right font-bold text-yellow-400"></td></tr>
          </table>
        </div>

        <!-- SubStream -->
        <div class="bg-gray-900 rounded-2xl p-6">
          <h3 class="text-xl font-semibold text-blue-400 mb-4">📱 SubStream (Visualização)</h3>
          <table class="w-full text-sm">
            <tr class="border-b border-gray-700"><td class="py-2">Resolução</td><td id="sub_res" class="text-right font-medium"></td></tr>
            <tr class="border-b border-gray-700"><td class="py-2">FPS</td><td id="sub_fps" class="text-right font-medium"></td></tr>
            <tr><td class="py-2">Bitrate por câmera</td><td id="sub_bitrate" class="text-right font-medium"></td></tr>
          </table>
        </div>
      </div>

      <div class="mt-6 bg-gray-800 rounded-xl p-5 text-center">
        <p class="text-green-400 font-medium" id="status"></p>
      </div>
    </div>
  </div>

  <script>
    function calcular() {
      const cameras = parseInt(document.getElementById('cameras').value) || 14;
      const res = document.getElementById('resolucao').value;
      const codec = document.getElementById('codec').value;
      const rede = parseInt(document.getElementById('rede').value);

      let bitrateMain, fpsMain, iframe;

      // Lógica de cálculo
      if (res === "4k") {
        bitrateMain = codec === "h265" ? 6000 : 8000;
        fpsMain = 10;
      } else if (res === "1080") {
        bitrateMain = codec === "h265" ? 1800 : 2200;
        fpsMain = 12;
      } else {
        bitrateMain = codec === "h265" ? 1000 : 1300;
        fpsMain = 12;
      }

      iframe = Math.round(fpsMain * 3);

      const totalMbps = Math.round((bitrateMain * cameras) / 1000);

      // Preenche MainStream
      document.getElementById('main_res').textContent = res === "4k" ? "4K" : res === "1080" ? "1080p" : "720p";
      document.getElementById('main_codec').textContent = codec.toUpperCase();
      document.getElementById('main_fps').textContent = fpsMain + " fps";
      document.getElementById('main_iframe').textContent = iframe;
      document.getElementById('main_bitrate').textContent = bitrateMain + " Kbps";

      // SubStream
      document.getElementById('sub_res').textContent = "720p / D1";
      document.getElementById('sub_fps').textContent = "8 fps";
      document.getElementById('sub_bitrate').textContent = (codec === "h265" ? "350" : "450") + " Kbps";

      document.getElementById('total_band').textContent = totalMbps + " Mbps";

      // Status
      const statusEl = document.getElementById('status');
      if (totalMbps < rede * 0.6) {
        statusEl.innerHTML = `✅ Excelente! Sua rede aguenta tranquilamente.`;
        statusEl.className = "text-green-400 font-medium";
      } else if (totalMbps < rede * 0.85) {
        statusEl.innerHTML = `⚠️ Bom, mas evite usar muita banda em outras coisas.`;
        statusEl.className = "text-yellow-400 font-medium";
      } else {
        statusEl.innerHTML = `❌ Rede pode ficar sobrecarregada. Reduza o bitrate.`;
        statusEl.className = "text-red-400 font-medium";
      }

      document.getElementById('resultado').classList.remove('hidden');
    }

    // Calcular automaticamente ao mudar valores
    document.querySelectorAll('input, select').forEach(el => {
      el.addEventListener('change', calcular);
    });

    // Primeira execução
    window.onload = calcular;
  </script>
</body>
</html>
